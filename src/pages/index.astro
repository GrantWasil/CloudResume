---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArrowIcon from "../components/ArrowIcon.astro";
import ContourMark from "../components/ContourMark.astro";

const practices = [
  {
    number: "01",
    title: "Find the real leverage",
    body: "I partner with leaders and teams to separate useful AI opportunities from novelty—clarifying the decision, the value, and what must change around the technology.",
  },
  {
    number: "02",
    title: "Design the whole change",
    body: "A model is only one part of a working system. I connect workflow design, governance, evaluation, product thinking, and organizational adoption from the beginning.",
  },
  {
    number: "03",
    title: "Build capability into the work",
    body: "I prototype close to the people doing the job, then turn what works into reusable workflows, shared practices, and systems teams can direct and improve.",
  },
];

const selectedWork = [
  {
    number: "01",
    type: "Current practice",
    title: "AI integration at organizational scale",
    description: "How I work across strategy, adoption, governance, education, and hands-on development at Gary Community Ventures.",
    href: "/work/organizational-ai-integration/",
    tags: ["Strategy", "Adoption", "Implementation"],
  },
  {
    number: "02",
    type: "Field note",
    title: "From isolated prompts to working systems",
    description: "A practical capability ladder for moving AI work from individual experimentation toward reliable, increasingly agentic practice.",
    href: "/notes/from-prompts-to-systems/",
    tags: ["Workflows", "Agentic systems", "Evaluation"],
  },
  {
    number: "03",
    type: "Operating foundation",
    title: "Reliability is part of the product",
    description: "What infrastructure, automation, and incident response taught me about building AI systems people can actually trust.",
    href: "/work/reliability-as-a-foundation/",
    tags: ["Systems", "Reliability", "Operations"],
  },
];
---

<BaseLayout>
  <!-- HERO: A Colorado contour route turns strategy into a working system. -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero__copy">
      <div class="hero__identity">
        <p class="hero__name">Grant Wasil</p>
        <p class="hero__eyebrow">AI Integration Engineer · Littleton, Colorado</p>
      </div>
      <h1 id="hero-title">
        Turning AI possibility into
        <em>working systems.</em>
      </h1>
      <p class="hero__lede">
        I help leaders decide how AI should change the way their organizations
        work—and stay close enough to implementation to make that change real.
      </p>
      <div class="hero__actions">
        <a class="primary-link" href="#connect">
          Compare notes
          <ArrowIcon />
        </a>
        <a class="text-link" href="#selected-work">
          See selected work
          <ArrowIcon direction="down" />
        </a>
      </div>
    </div>

    <div class="hero__visual">
      <img
        class="hero__portrait"
        src="/grant-wasil-1600.webp"
        srcset="/grant-wasil-800.webp 800w, /grant-wasil-1600.webp 1600w"
        sizes="(max-width: 1100px) 100vw, 44vw"
        width="1600"
        height="1067"
        alt="Grant Wasil smiling in a sunlit office"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <ContourMark />
      <p class="hero__visual-note">Strategy should end in something people can use.</p>
    </div>

    <dl class="hero__facts">
      <div>
        <dt>Current role</dt>
        <dd>AI Integration Engineer<br />Gary Community Ventures</dd>
      </div>
      <div>
        <dt>Working across</dt>
        <dd>Strategy · Products · Adoption<br />Workflows · Agentic systems</dd>
      </div>
      <div>
        <dt>Core question</dt>
        <dd>How does possibility become dependable practice?</dd>
      </div>
    </dl>
  </section>

  <section class="practice section-shell" id="practice" aria-labelledby="practice-title">
    <div class="section-heading">
      <p class="section-kicker">The practice</p>
      <h2 id="practice-title">Strategy, close enough to implementation.</h2>
      <p>
        The hardest AI work lives between a compelling demo and a dependable
        way of working. That is the space I help organizations navigate.
      </p>
    </div>

    <ol class="practice-list">
      {practices.map((item) => (
        <li>
          <span class="practice-list__number">{item.number}</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </li>
      ))}
    </ol>
  </section>

  <aside class="manifesto" aria-label="Working principle">
    <p>AI implementation is not a software rollout.</p>
    <p>It is a redesign of decisions, capabilities, and systems.</p>
  </aside>

  <section class="work section-shell" id="selected-work" aria-labelledby="work-title">
    <div class="section-heading section-heading--compact">
      <p class="section-kicker">Selected thinking & work</p>
      <h2 id="work-title">Evidence over adjectives.</h2>
    </div>

    <div class="work-list">
      {selectedWork.map((item) => (
        <article class="work-item">
          <a href={item.href} aria-label={`Read ${item.title}`}>
            <div class="work-item__index">
              <span>{item.number}</span>
              <span>{item.type}</span>
            </div>
            <div class="work-item__copy">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
              <ul aria-label="Topics">
                {item.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            </div>
            <ArrowIcon />
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="about section-shell" id="about" aria-labelledby="about-title">
    <div class="about__title">
      <p class="section-kicker">About</p>
      <h2 id="about-title">I came to AI through systems—not hype.</h2>
    </div>
    <div class="about__story">
      <p class="about__lead">
        My path runs through customer-facing work, web development, election
        operations, and site reliability engineering. Each chapter taught me
        the same thing: technology matters when it helps people make better
        decisions and do stronger work.
      </p>
      <p>
        Today, I work across AI strategy, organizational adoption, education,
        venture design, and hands-on product development. I’m most useful when
        the direction is still taking shape and someone needs to connect the
        organizational question to a system that can be tested in the real world.
      </p>
      <p>
        I also care about growing the field as a community. I teach practical
        AI skills, convene peer learning, and trade notes openly with other
        practitioners navigating an emerging discipline.
      </p>
    </div>
    <div class="about__aside">
      <p class="about__aside-label">Away from the diagram</p>
      <p>
        You’ll usually find me around a board game, in the Colorado mountain
        air, or building a space where curious people can learn from one another.
      </p>
      <a class="text-link" href="https://www.linkedin.com/in/grant-wasil/">
        More on LinkedIn
        <ArrowIcon />
      </a>
    </div>
  </section>
</BaseLayout>
