---
import BaseLayout from "./BaseLayout.astro";
import ArrowIcon from "../components/ArrowIcon.astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  intro: string;
  number: string;
}

const { eyebrow, title, description, intro, number } = Astro.props;
---

<BaseLayout title={`${title} — Grant Wasil`} description={description}>
  <article class="essay">
    <header class="essay-hero">
      <div class="essay-hero__meta">
        <p class="section-kicker">{eyebrow}</p>
        <p class="essay-hero__number">{number}</p>
      </div>
      <div class="essay-hero__title">
        <h1>{title}</h1>
      </div>
      <div class="essay-hero__intro">
        <p>{intro}</p>
      </div>
    </header>

    <div class="essay-body">
      <slot />
    </div>

    <nav class="essay-return" aria-label="Return to homepage">
      <a class="text-link" href="/#selected-work">
        <ArrowIcon />
        Back to selected work
      </a>
    </nav>
  </article>
</BaseLayout>
